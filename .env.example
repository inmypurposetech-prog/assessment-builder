# Create a project at https://supabase.com and copy these values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — only needed to apply SQL migrations from the CLI (never commit the real URI)
# Dashboard → Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-….pooler.supabase.com:6543/postgres

# Phase 1B generation cost controls (bank-first; AI gap-fill only if key + non-bank model)
# GENERATION_MODEL=bank-only
# GENERATION_MODEL=gpt-4o-mini
# GENERATION_MODEL=gemini-2.0-flash
# GENERATION_MAX_TOKENS=2048
# GENERATION_MONTHLY_CAP=30
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
