# Create a project at https://supabase.com and copy these values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — only needed to apply SQL migrations from the CLI (never commit the real URI)
# Dashboard → Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-….pooler.supabase.com:6543/postgres
