# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local smoke artefacts
.tmp/

# Parent curriculum PDFs (local only — copyright + size). Keep MANIFEST.md / README tracked.
docs/parent-samples/**/*.pdf
docs/parent-samples/**/*.docx
docs/parent-samples/**/*.doc

# Local PDF text extracts (copyrighted exam content — do not commit)
docs/parent-samples/**/_extracts/
